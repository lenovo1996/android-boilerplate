# top-most EditorConfig file
root = true

[*.{kt,kts}]
charset                  = utf-8
indent_style             = space
indent_size              = 2
trim_trailing_whitespace = true
insert_final_newline     = true
max_line_length          = 120

[*.{java,xml,gradle}]
charset                  = utf-8
indent_style             = space
indent_size              = 2
trim_trailing_whitespace = true
insert_final_newline     = true

[*.toml]
charset                  = utf-8
indent_style             = space
indent_size              = 2
trim_trailing_whitespace = true
insert_final_newline     = true

[*.{yml,yaml}]
charset                  = utf-8
indent_style             = space
indent_size              = 2
trim_trailing_whitespace = true
insert_final_newline     = true

[*.md]
trim_trailing_whitespace = false